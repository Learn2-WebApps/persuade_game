{
  "name": "persuade-game",
  "version": "0.1.0",
  "private": true,
  "description": "설득 게임 - 시나리오 기반 설득 훈련 앱",
  "scripts": {
    "seed": "node scripts/seed.js",
    "seed:master": "node scripts/seed-master.js",
    "rooms:list": "node scripts/delete-rooms.js --list",
    "rooms:delete": "node scripts/delete-rooms.js",
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "wrangler pages dev public --port 8788",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "firebase-admin": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
