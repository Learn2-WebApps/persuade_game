rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// 설득 게임 Firestore 보안 규칙
//
// 【대전제】이 앱은 Firebase Auth를 쓰지 않는다 (익명·무인증 접근).
//   → request.auth 는 항상 null 이므로 "누가 요청했는지"를 규칙이 알 수 없다.
//   → 따라서 "본인 문서만 수정" 같은 소유권 기반 제약은 원천적으로 불가능하다.
//   → 방 코드(4자리)를 아는 사람 = 그 방에 접근 권한이 있는 사람, 이 수준이 한계다.
//
// 이 파일이 확실히 막는 것:
//   · 클라이언트에서의 모든 삭제 (삭제는 서버 API /api/admin-delete-room 전용)
//   · 방 목록 열거 (rooms 컬렉션 list) — 남의 방 코드 수집 차단
//   · 참가자 명단 열거 (players list) — 이름·소속 대량 수집 차단
//   · 방 문서·스테이지 문서의 클라이언트 쓰기 (생성·수정 전부)
//   · templates/* 전면 차단 (정답 원본)
//   · 말도 안 되는 점수 값 (범위·타입 검증)
//
// 이 파일로 막을 수 '없는' 것 — 코드 변경이 필요하다:
//   · 스테이지 문서의 정답 필드(hiddenNeed, scoringExamples) 노출
//     → 규칙은 필드 단위 읽기 제한이 불가능. /api/stage 로 공개 필드만 내려줘야 한다.
//   · "플레이하지 않고 그럴듯한 점수 써넣기"
//     → 범위 검증까지가 한계. 근본 해결은 결과 저장을 서버 API로 옮기는 것.
//   · 방 코드를 아는 제3자가 그 방의 남의 플레이어 문서를 get 하는 것
//     → playerId 가 "소속__이름" 규칙이라 추측 가능. Auth 도입 전엔 방어 불가.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 ────────────────────────────────────────────────────
    function isStagesCol(name) {
      return name == 'stages_work' || name == 'stages_life';
    }
    function isResultsCol(name) {
      return name == 'stageResults_work' || name == 'stageResults_life';
    }
    function roomExists(code) {
      return exists(/databases/$(database)/documents/rooms/$(code));
    }
    // 0~hi 범위의 숫자인지 (점수 조작 방어 — 완벽하진 않은 최선)
    function inRange(v, hi) {
      return v is number && v >= 0 && v <= hi;
    }

    // ── 0) 기본 전면 거부 ───────────────────────────────────────
    // 아래에서 명시적으로 허용한 경로 외에는 전부 막힌다.
    // (규칙은 OR로 평가되므로 이 블록이 아래 allow를 무효화하지는 않는다.
    //  명시적 문서화 + 새 컬렉션이 생겨도 기본 차단되게 하는 안전장치다)
    match /{document=**} {
      allow read, write: if false;
    }

    // ── 1) 방 문서 ──────────────────────────────────────────────
    // get 만 허용: 입장 화면의 status 확인, 플레이/맵의 settings 구독에 필요.
    // list 차단: rooms 컬렉션을 훑어 존재하는 방 코드를 수집하는 것을 막는다.
    // write 전면 차단: 방 생성·상태변경·설정변경은 모두 관리자 서버 API로 가야 한다.
    match /rooms/{code} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // ── 2) 스테이지 (읽기 전용) ─────────────────────────────────
    // 맵의 목록 조회와 플레이 화면의 단건 조회에 필요하다.
    // ⚠️ 이 문서에는 정답 필드가 들어 있고 규칙으로는 필드를 가릴 수 없다.
    //    /api/stage 도입 전까지는 "정답이 보이는 상태"임을 인지하고 쓸 것.
    // {stagesCol} 와일드카드는 players 컬렉션과도 형태가 겹치지만,
    // isStagesCol() 조건이 false라 players 에는 아무 권한도 주지 않는다.
    match /rooms/{code}/{stagesCol}/{stageId} {
      allow get, list: if isStagesCol(stagesCol);
      allow write: if false;
    }

    // ── 3) 플레이어 문서 ────────────────────────────────────────
    // get 허용 / list 차단: 참가자 명단(이름·소속·점수)을 통째로 긁어가는 것을 막는다.
    // 남의 문서를 "정확한 playerId를 알고" 열어보는 것은 Auth 없이는 막을 수 없다.
    match /rooms/{code}/players/{playerId} {

      // 신규 입장: 실제 존재하는 방에만, 점수 0으로 시작해야 한다
      function validNewPlayer() {
        let d = request.resource.data;
        return d.keys().hasOnly(['name', 'affiliation', 'enteredAt', 'lastActiveAt',
                                 'totalScore', 'status', 'progress'])
            && d.name is string && d.name.size() > 0 && d.name.size() <= 40
            && d.affiliation is string && d.affiliation.size() > 0 && d.affiliation.size() <= 60
            && d.totalScore == 0
            && d.status == 'active';
      }

      // 진행 갱신: 이름·소속·입장시각은 못 바꾸고, 점수는 범위 안이어야 한다.
      // (한 트랙 5스테이지 × 100점 = 500, 두 트랙 = 1000이 이론상 최대)
      function validPlayerUpdate() {
        let d = request.resource.data;
        let old = resource.data;
        return d.keys().hasOnly(['name', 'affiliation', 'enteredAt', 'lastActiveAt',
                                 'totalScore', 'status', 'progress',
                                 'finalReports', 'finalReportAt'])
            && d.name == old.name
            && d.affiliation == old.affiliation
            && d.enteredAt == old.enteredAt
            && inRange(d.totalScore, 1000)
            && (!('work' in d.progress) || inRange(d.progress.work.totalScore, 500))
            && (!('life' in d.progress) || inRange(d.progress.life.totalScore, 500));
      }

      allow get: if true;
      allow list: if false;
      allow create: if roomExists(code) && validNewPlayer();
      allow update: if validPlayerUpdate();
      allow delete: if false;   // 삭제는 서버 API 전용
    }

    // ── 4) 스테이지 결과 ────────────────────────────────────────
    // 맵의 잠금 계산·리포트에 필요해 읽기는 열되, 쓰기는 형태와 범위를 검증한다.
    // ⚠️ 여전히 "플레이 없이 stageScore: 100" 을 쓸 수 있다.
    //    막으려면 저장을 서버 API(/api/save-result 같은)로 옮겨야 한다.
    match /rooms/{code}/players/{playerId}/{resultsCol}/{stageId} {

      function validResult() {
        let d = request.resource.data;
        return d.keys().hasOnly(['stageScore', 'turnCount', 'turns', 'completedAt'])
            && inRange(d.stageScore, 100)      // 게이지 상한과 동일
            && inRange(d.turnCount, 200)
            && d.turns is list && d.turns.size() <= 200;
      }

      allow get, list: if isResultsCol(resultsCol);
      allow create, update: if isResultsCol(resultsCol) && validResult();
      allow delete: if false;
    }

    // ── 5) 마스터 템플릿 — 전면 차단 ────────────────────────────
    // 모든 시나리오의 정답 원본이다. 방 생성(복사)은 서버로 옮겨야 하며,
    // 클라이언트가 여기를 읽을 이유는 없다.
    match /templates/{document=**} {
      allow read, write: if false;
    }

    // ═════════════════════════════════════════════════════════════
    // 【전환용 임시 블록】 관리자 화면을 당장 살려야 할 때만 주석 해제
    //
    // ⚠️ 경고: 아래를 켜면 "누구나" 방을 만들고, 설정을 바꾸고, 전체 방 목록과
    //    참가자 명단(이름·소속·점수)을 열람할 수 있다. 관리자 비밀번호는
    //    Firestore가 검사하지 않기 때문이다. 위의 차단 효과 상당수가 사라진다.
    //    관리자 기능을 서버 API(/api/admin-*)로 옮기기 전까지의 임시 조치로만 쓸 것.
    //
    // match /rooms/{code} {
    //   allow list: if true;                      // 방 목록
    //   allow create, update: if true;            // 방 생성·상태·설정 변경
    // }
    // match /rooms/{code}/players/{playerId} {
    //   allow list: if true;                      // 참가자 모니터링
    // }
    // match /rooms/{code}/{stagesCol}/{stageId} {
    //   allow create: if isStagesCol(stagesCol);  // 방 생성 시 스테이지 복사
    // }
    // match /templates/{track} {
    //   allow get: if true;                       // 마스터 복사용 (정답 노출됨)
    // }
    // match /templates/{track}/stages/{stageId} {
    //   allow get, list: if true;
    // }
    // ═════════════════════════════════════════════════════════════
  }
}
