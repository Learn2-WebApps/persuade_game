# 이 파일을 .dev.vars 로 복사한 뒤 실제 값을 채워 넣으세요.
# .dev.vars 는 .gitignore 에 등록되어 있어 커밋되지 않습니다.
#
#   cp .dev.vars.example .dev.vars   (또는 파일 복사 후 이름 변경)

# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=여기에_GEMINI_API_키

# Firebase 서비스 계정 정보 — serviceAccountKey.json 에서 그대로 복사
#   FIREBASE_PROJECT_ID   ← project_id
#   FIREBASE_CLIENT_EMAIL ← client_email
#   FIREBASE_PRIVATE_KEY  ← private_key (줄바꿈이 \n 으로 표시된 한 줄 전체를 따옴표로 감싸 붙여넣기)
FIREBASE_PROJECT_ID=여기에_프로젝트_ID
FIREBASE_CLIENT_EMAIL=xxx@xxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 실행 환경 표시 — 관리자 인증에서만 쓰인다.
#   development : ADMIN_ID/ADMIN_PASSWORD를 비워두면 개발용 기본값(learn2/0067)으로 폴백
#   그 외(값이 없는 경우 포함) : 프로덕션으로 보고 폴백 없이 500으로 막는다
# 로컬은 development, 배포 환경은 production (배포 값은 wrangler.toml의 [env.production.vars]
# 또는 Cloudflare 대시보드에서 지정한다 — 이 파일은 로컬 전용이라 배포에 올라가지 않는다)
ENVIRONMENT=development

# 관리자 페이지 로그인 (아이디 + 비밀번호)
# 개발용 기본값: learn2 / 0067 — 위 ENVIRONMENT=development 일 때만 폴백이 허용된다.
# ⚠️ 배포 시엔 반드시 Cloudflare Secret에 다른 값으로 등록할 것 (기본값은 저장소에 공개돼 있다).
#    등록하지 않으면 프로덕션 관리자 API가 500으로 막힌다.
ADMIN_ID=learn2
ADMIN_PASSWORD=0067
